# ─────────────────────────────────────────────────────────────────
# BandiRadar — .gitignore
# ─────────────────────────────────────────────────────────────────

# Dati identificativi dei clienti — NON committare MAI per ragioni GDPR
# Vedi data/aziende.json per lo schema pubblico anonimizzato
data/dati_clienti_privati.json

# File pulizia locale — contiene codici cliente da eliminare, non va su GitHub
data/da_eliminare.json

# Secrets locali (mai committarli)
.bandiradar_secrets
*.env
*.env.local

# Backup automatici
_backup_locale/
data/*.bak
data/*_backup_*.csv
data/*_backup_prefix_*.csv
*.rotto-*.bak

# Sistema
.DS_Store
Thumbs.db
desktop.ini

# Editor
.vscode/
.idea/
*.swp
*.swo
*~

# Report diagnostico del controllo coerenza notturno (transitorio:
# rigenerato a ogni run e allegato all'email, non serve versionarlo)
data/coerenza_report.json

# Cache Python (per gli script in scripts/)
__pycache__/
*.pyc
*.pyo
.pytest_cache/
